# ── Copy this file to .env and fill in your values ──────────────────────────

# Required in production
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Leave blank to use SQLite locally.
DATABASE_URL=

# Flask
FLASK_ENV=development      # set to 'production' on the deploy host
FLASK_DEBUG=true           # set to 'false' in production

# WhatsApp Cloud API (optional — set WHATSAPP_ENABLED=true to activate)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Cloudflare R2 (uploads dual-write; module silently no-ops if any are missing)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Anthropic API key — used by accounting receipt OCR; optional
ANTHROPIC_API_KEY=

# ─── Initial admin bootstrap ─────────────────────────────────────────────────
# There is NO default admin password. The previous `admin / admin123` auto-seed
# has been removed. To create the FIRST admin on a fresh install, run:
#
#     flask --app run.py admin create
#
# The CLI prompts for username, email, and password (hidden input via getpass).
# To rotate an existing admin's password without touching the DB directly:
#
#     flask --app run.py admin reset-password --username <name>
#
# Production admins MUST use a strong password (the CLI rejects passwords
# under 12 characters and a small blocklist of known-weak strings such as
# "admin123", "password", etc.).
# ─────────────────────────────────────────────────────────────────────────────

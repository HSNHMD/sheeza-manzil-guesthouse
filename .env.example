# ── Copy this file to .env and fill in your values ──────────────────────────

# Required in production
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Leave blank to use SQLite locally.
DATABASE_URL=

# Flask
FLASK_ENV=development      # set to 'production' on the deploy host
FLASK_DEBUG=true           # set to 'false' in production

# WhatsApp Cloud API (optional — set WHATSAPP_ENABLED=true to activate sending)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Inbound webhook (V1: receive-and-display only; never auto-replies):
#   WHATSAPP_WEBHOOK_VERIFY_TOKEN — random string shared with Meta App
#                                   Dashboard → Webhooks → Verify Token.
#                                   Used by GET /webhooks/whatsapp.
#   WHATSAPP_APP_SECRET           — Meta App Secret from
#                                   App Dashboard → Settings → Basic.
#                                   Used to verify X-Hub-Signature-256 HMAC
#                                   on POST /webhooks/whatsapp.
# Both are required for the inbound webhook to function. If unset, the
# webhook fails-safe (returns 403 to all requests).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Cloudflare R2 (uploads dual-write; module silently no-ops if any are missing)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ─── AI Draft Assistant (admin-only, draft-only) ───────────────────────────
# Generates polite reply drafts on the booking detail page. NEVER auto-sends.
# All providers fail gracefully if their key is unset — feature simply
# shows "AI draft assistant is not configured." until a key is added.
#
# Choose ONE provider with AI_DRAFT_PROVIDER. Defaults to 'gemini' if unset.
AI_DRAFT_PROVIDER=gemini
# Optional model override (provider-agnostic). Falls back to the provider
# default if unset:
#   gemini    → gemini-2.5-flash-lite
#   anthropic → claude-sonnet-4-6
AI_DRAFT_MODEL=

# Google Gemini API key — required if AI_DRAFT_PROVIDER=gemini.
# Get one from https://aistudio.google.com/apikey (Generative Language API).
GEMINI_API_KEY=

# Anthropic API key — used by accounting receipt OCR (always) AND by the
# AI draft assistant when AI_DRAFT_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Legacy override for Anthropic model only. AI_DRAFT_MODEL takes precedence.
ANTHROPIC_MODEL=

# ─── Initial admin bootstrap ─────────────────────────────────────────────────
# There is NO default admin password. The previous `admin / admin123` auto-seed
# has been removed. To create the FIRST admin on a fresh install, run:
#
#     flask --app run.py admin create
#
# The CLI prompts for username, email, and password (hidden input via getpass).
# To rotate an existing admin's password without touching the DB directly:
#
#     flask --app run.py admin reset-password --username <name>
#
# Production admins MUST use a strong password (the CLI rejects passwords
# under 12 characters and a small blocklist of known-weak strings such as
# "admin123", "password", etc.).
# ─────────────────────────────────────────────────────────────────────────────

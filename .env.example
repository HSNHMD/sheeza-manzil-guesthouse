# ── Copy this file to .env and fill in your values ──────────────────────────
# Railway sets DATABASE_URL automatically — you only need it for local Postgres.

# Required in production
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Leave blank to use SQLite locally.
# Railway fills this automatically when you add a Postgres plugin.
DATABASE_URL=

# Flask
FLASK_ENV=development      # set to 'production' on Railway
FLASK_DEBUG=true           # set to 'false' on Railway

# WhatsApp Cloud API (optional — set WHATSAPP_ENABLED=true to activate)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
